# ── Contact form (SMTP) ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Spaceship Spacemail:
#   Verify exact hostname in Spaceship dashboard → Email → your mailbox → Settings
#   Port: 587 (STARTTLS, recommended) or 465 (SSL)
#   User: your full Spacemail address  e.g. you@yourdomain.com
#   Pass: your Spacemail account password
#
# Other providers:
#   Gmail:   smtp.gmail.com  port 587  (needs 16-char App Password)
#   Outlook: smtp.office365.com  port 587

CONTACT_SMTP_HOST=smtp.spacemail.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=you@yourdomain.com
CONTACT_SMTP_PASS=your_spacemail_password_here

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=you@yourdomain.com
